{
  "version": 2,
  "framework": null,
  "installCommand": "npm install && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://resume-analyzer-2-jsq6.onrender.com/api/$1"
    },
    {
      "source": "/api",
      "destination": "https://resume-analyzer-2-jsq6.onrender.com/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
